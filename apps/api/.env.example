# Copy to apps/api/.env and fill in values.

# Enable $1 homeowner acceptance fee on bid accept
PAYMENTS_ENABLED=false

# Stripe (test keys first — https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Web app (Vercel) — publishable key for Payment Element
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Persistent job photos (production) -------------------------------------
# Local dev: leave MEDIA_LOCAL_ROOT empty (uses apps/api/.dev-media).
# Railway: attach volume at /data/media and set MEDIA_LOCAL_ROOT=/data/media
# See docs/Deploy-Vercel-Railway-Neon.md Step 6c.
MEDIA_LOCAL_ROOT=
PUBLIC_WEB_URL=https://dojobid.com
MEDIA_PUBLIC_BASE_URL=https://dojobid.com/api/v1/dev-media

# Optional: Cloudflare R2 / S3 (Step 6d in deploy guide)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MEDIA_S3_BUCKET=
MEDIA_S3_ENDPOINT=
