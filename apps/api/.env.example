DATABASE_URL="postgresql://contractor:contractor@localhost:5432/contractor_bidder?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL="30d"
API_PORT=4000
API_CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"
PAYMENTS_ENABLED=false
MESSAGING_GROUP_VISIBLE=false
PROFILE_REQUIRE_VERIFICATION=false
JOBS_MAX_PHOTOS=4
AI_JOB_DESCRIPTION_ENABLED=true
# Inexpensive LLM via OpenRouter (~$0.04/1M input tokens for Qwen 2.5 7B).
# Get a key at https://openrouter.ai/keys — when unset, built-in heuristics still suggest job details.
OPENROUTER_API_KEY=""
AI_MODEL="qwen/qwen-2.5-7b-instruct"
# Optional override (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
AI_PHOTO_EDIT_ENABLED=true
# FLUX Kontext Dev on Replicate — lower cost than Pro/Max (~$0.025/image).
# Get a token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=""
AI_PHOTO_EDIT_MODEL="black-forest-labs/flux-kontext-dev"
# AI_PHOTO_EDIT_WAIT_SECONDS=120  # total client timeout; sync Prefer header is capped at 60s
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
AWS_REGION="us-east-1"
MEDIA_S3_BUCKET=""
MEDIA_S3_ENDPOINT=""
# Persistent local uploads (Railway volume mount path in production).
# MEDIA_LOCAL_ROOT="/app/apps/api/.dev-media"
# e.g. http://192.168.1.20:4000/api/v1/dev-media — for iPhone/Expo Go to load uploads.
# Upload PUT URLs always use the API host; this only affects stored file URLs for display.
# Required for AI photo edit so Replicate can fetch source images over HTTPS.
MEDIA_PUBLIC_BASE_URL="https://dojobid.com/api/v1/dev-media"