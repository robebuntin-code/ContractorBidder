# Copy to apps/api/.env and fill in values.

# Enable $1 homeowner acceptance fee on bid accept
PAYMENTS_ENABLED=false

# Stripe (test keys first — https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Web app (Vercel) — publishable key for Payment Element
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
