{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_DEV_CLIENT": "1",
        "EXPO_PUBLIC_API_URL": "https://dojobid-api-production.up.railway.app/api/v1"
      },
      "ios": {
        "simulator": false
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_DEV_CLIENT": "1",
        "EXPO_PUBLIC_API_URL": "https://dojobid-api-production.up.railway.app/api/v1"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://dojobid-api-production.up.railway.app/api/v1"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://dojobid-api-production.up.railway.app/api/v1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
