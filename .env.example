# ----------------------------------------------------------------------------
# ContractorBidder environment example. Copy to .env and adjust.
# ----------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# Local docker-compose Postgres (see docker-compose.yml):
DATABASE_URL="postgresql://contractor:contractor@localhost:5432/contractor_bidder?schema=public"
# Or a hosted Postgres (Neon/Supabase), e.g.:
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- Redis (cache / rate limit / queues) ------------------------------------
REDIS_URL="redis://localhost:6379"

# --- Auth / JWT -------------------------------------------------------------
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL="30d"

# --- API --------------------------------------------------------------------
API_PORT=4000
API_CORS_ORIGIN="http://localhost:3000"

# --- Feature flags ----------------------------------------------------------
PAYMENTS_ENABLED=false
MESSAGING_GROUP_VISIBLE=false
PROFILE_REQUIRE_VERIFICATION=false
JOBS_MAX_PHOTOS=4

# --- Stripe (only when PAYMENTS_ENABLED=true) -------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Media / object storage -------------------------------------------------
# Leave MEDIA_S3_BUCKET empty to use the dev placeholder uploader.
AWS_REGION="us-east-1"
MEDIA_S3_BUCKET=""
# Optional: S3-compatible endpoint (e.g. MinIO/R2) -> uses path-style addressing.
MEDIA_S3_ENDPOINT=""
# Optional: public/CDN base URL for stored objects (else a signed GET is returned).
MEDIA_PUBLIC_BASE_URL=""

# --- Web client -------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
