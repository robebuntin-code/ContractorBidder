# ----------------------------------------------------------------------------
# ContractorBidder environment example. Copy to .env and adjust.
# ----------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# Local docker-compose Postgres (see docker-compose.yml):
DATABASE_URL="postgresql://contractor:contractor@localhost:5432/contractor_bidder?schema=public"
# Or a hosted Postgres (Neon/Supabase), e.g.:
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- Redis (cache / rate limit / queues) ------------------------------------
REDIS_URL="redis://localhost:6379"

# --- Auth / JWT -------------------------------------------------------------
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL="30d"

# --- API --------------------------------------------------------------------
API_PORT=4000
API_CORS_ORIGIN="http://localhost:3000"

# --- Feature flags ----------------------------------------------------------
PAYMENTS_ENABLED=false
MESSAGING_GROUP_VISIBLE=false
PROFILE_REQUIRE_VERIFICATION=false
JOBS_MAX_PHOTOS=4
AI_PHOTO_EDIT_ENABLED=true
# Replicate model for job scope previews (dev is cheapest Kontext tier on Replicate).
AI_PHOTO_EDIT_MODEL=black-forest-labs/flux-kontext-dev
REPLICATE_API_TOKEN=""

# --- Stripe (only when PAYMENTS_ENABLED=true) -------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Media / object storage -------------------------------------------------
# Production (Railway): attach a volume at /data/media — see Deploy guide Step 6c.
MEDIA_LOCAL_ROOT=
PUBLIC_WEB_URL=https://dojobid.com
MEDIA_PUBLIC_BASE_URL=https://dojobid.com/api/v1/dev-media

# Optional upgrade: Cloudflare R2 or AWS S3 (recommended at scale).
# When MEDIA_S3_BUCKET is set, uploads go directly to object storage.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MEDIA_S3_BUCKET=
MEDIA_S3_ENDPOINT=

# --- Web client -------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
